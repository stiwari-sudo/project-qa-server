# ---- projectqa-api ----
APP_ENV=development
API_V1_PREFIX=/api/v1

# Database (asyncpg DSN). In docker-compose the host is "db".
DATABASE_URL=postgresql+asyncpg://qa:qa@db:5432/projectqa

# Comma-separated allowed CORS origins (the web app).
CORS_ORIGINS=http://localhost:3000

# Auth provider: "dev" (header stub, local only) or "azure" (Entra ID JWKS).
# The app refuses to boot with APP_ENV=production unless this is "azure".
AUTH_PROVIDER=dev
DEV_USER_EMAIL=engineer@hts.uk.com

# Azure AD (only used when AUTH_PROVIDER=azure).
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_AUDIENCE=

# Director overview: "site" (stage-order proxy) or "cmap" (after CMAP sync lands).
CONSTRUCTION_SOURCE=site
# Stage order the proxy treats as construction. The migrated HTS dataset has no
# Site-stage QA, so real-data deployments need 4 (Pre-construction) — the
# default 5 leaves the director overview empty.
CONSTRUCTION_STAGE_ORDER=4
CALC_PACK_QUESTION_IDS=q_detailed_sd_5,q_pretender_sd_5,q_precon_sd_5
# The question a director's Building Control "confirm" writes to.
CALC_PACK_PRIMARY_QUESTION_ID=q_precon_sd_5

# QA file share root for building folder scaffolding + the Building Control
# scan. Empty = disabled. Use the UNC root (e.g. \\server\share), NOT a mapped
# drive letter — those are per-user and invisible to a service account.
QA_SHARE_ROOT=

# Demo seed data (fake users + projects 24001-24008). Never enable against a
# database holding real QA data; refused when APP_ENV is production.
SEED_SAMPLE_DATA=false

# Deadline reminders (Phase 3).
REMINDER_OFFSETS=14,7,3,1
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=qa-noreply@hts.uk.com
SMTP_TLS=true
