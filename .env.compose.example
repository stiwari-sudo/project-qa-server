# ============================================================================
# HTS Project QA — single environment file for the full-stack `docker compose up`.
# Copy to `.env` next to docker-compose.yml (the defaults below work for dev).
#   cp .env.compose.example .env && docker compose up --build
#
# NOTE: this is the *stack* env (db + api + web). For running the API on its
# own (without docker), use this repo's `.env.example` instead.
# ============================================================================

# ---- Postgres ----
POSTGRES_USER=qa
POSTGRES_PASSWORD=qa
POSTGRES_DB=projectqa
DB_PORT=5432

# ---- Host port mappings ----
API_PORT=8000
WEB_PORT=3000

# ---- API ----
APP_ENV=development
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000

# Auth: "dev" header stub (local dev) or "azure" (Entra ID — implemented).
# APP_ENV=production refuses to boot unless AUTH_PROVIDER=azure.
AUTH_PROVIDER=dev
DEV_USER_EMAIL=engineer@hts.uk.com

# Azure AD (only used when AUTH_PROVIDER=azure).
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_AUDIENCE=

# Director overview: "site" (stage-order proxy) or "cmap" (after CMAP sync).
CONSTRUCTION_SOURCE=site
# Stage order the proxy treats as construction (real-data deployments: 4).
CONSTRUCTION_STAGE_ORDER=5
CALC_PACK_QUESTION_IDS=q_detailed_sd_5,q_pretender_sd_5,q_precon_sd_5
# The question a director's Building Control "confirm" writes to.
CALC_PACK_PRIMARY_QUESTION_ID=q_precon_sd_5

# QA file share root (building folder scaffolding + Building Control scan).
# Empty = disabled. Use a UNC root, not a mapped drive letter.
QA_SHARE_ROOT=

# Demo seed data (fake users + projects 24001-24008) for the dev stack.
# NEVER enable against a database holding real QA data; refused in production.
SEED_SAMPLE_DATA=true

# Deadline reminders (Phase 3).
REMINDER_OFFSETS=14,7,3,1
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=qa-noreply@hts.uk.com
SMTP_TLS=true

# ---- Web (NEXT_PUBLIC_* are baked into the browser bundle at build time) ----
# The browser reaches the API on the host-published port, so use localhost.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
